// Hp_vos3 clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace hp_vos3 {

    entity Job {
        id: string @unique
        jcl: string
        class_: string
        owner: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Dataset {
        id: string @unique
        name: string
        dsorg: string
        recfm: string
        sizeTracks: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Region {
        id: string @unique
        name: string
        type: string
        maxTasks: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Subsystem {
        id: string @unique
        name: string
        type: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Transaction {
        id: string @unique
        code: string
        program: string
        regionId: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Queue {
        id: string @unique
        name: string
        depth: integer
        maxDepth: integer
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
